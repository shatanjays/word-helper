{
  "name": "word-helper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:prod": "SITE_ENV=production SHARD_PAGES=1 HOST_CANONICAL=https://wordhelper-online.pages.dev node scripts/build.mjs",
    "build:prod:unsharded": "SITE_ENV=production HOST_CANONICAL=https://wordhelper-online.pages.dev node scripts/build.mjs",
    "build:live": "SITE_ENV=production SHARD_PAGES=1 HOST_CANONICAL=https://wordhelper.online node scripts/build.mjs",
    "dev": "node scripts/dev-server.mjs",
    "keepalive": "node scripts/keep-local-server.mjs",
    "preview": "node scripts/dev-server.mjs --port 4173",
    "check:domain": "node scripts/check-domain-email.mjs",
    "check:deploy": "node scripts/check-deploy-output.mjs",
    "validate": "node --max-old-space-size=4096 scripts/validate-build.mjs",
    "verify:deploy": "npm run build:prod && npm run validate && npm run check:domain && npm run check:deploy"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "esbuild": "^0.28.1"
  }
}
